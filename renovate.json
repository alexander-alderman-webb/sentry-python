{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["custom.regex", "github-actions", "pep621"],
  "includePaths": [
    "pyproject.toml",
    "uv.lock",
    "scripts/split_tox_gh_actions/templates/test_group.jinja",
    "scripts/split_tox_gh_actions/templates/test_orchestrator.jinja",
    ".github/workflows/test.yml",
    ".github/workflows/test-integrations-*.yml"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group package updates.",
      "matchManagers": ["pep621"],
      "groupName": "Packages",
      "groupSlug": "packages",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "separateMultipleMajor": false
    },
    {
      "description": "Group GitHub Actions updates.",
      "matchManagers": ["custom.regex", "github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "separateMultipleMajor": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update actions/checkout in workflow templates",
      "managerFilePatterns": [
        "/^scripts\\/split_tox_gh_actions\\/templates\\/(test_group|test_orchestrator)\\.jinja$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*(?:-[ \\t]+)?uses:[ \\t]+)actions\\/checkout@(?<currentDigest>[a-f0-9]{40})[ \\t]+#[ \\t]+(?<currentValue>v?\\d+(?:\\.\\d+){0,2})"
      ],
      "depNameTemplate": "actions/checkout",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "github-actions",
      "autoReplaceStringTemplate": "{{{indent}}}actions/checkout@{{{currentDigest}}} # {{{newValue}}}"
    },
    {
      "customType": "regex",
      "description": "Update astral-sh/setup-uv in workflow templates",
      "managerFilePatterns": [
        "/^scripts\\/split_tox_gh_actions\\/templates\\/(test_group|test_orchestrator)\\.jinja$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*(?:-[ \\t]+)?uses:[ \\t]+)astral-sh\\/setup-uv@(?<currentDigest>[a-f0-9]{40})[ \\t]+#[ \\t]+(?<currentValue>v?\\d+(?:\\.\\d+){0,2})"
      ],
      "depNameTemplate": "astral-sh/setup-uv",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "github-actions",
      "autoReplaceStringTemplate": "{{{indent}}}astral-sh/setup-uv@{{{currentDigest}}} # {{{newValue}}}"
    },
    {
      "customType": "regex",
      "description": "Update getsentry/action-clickhouse-in-ci in workflow templates",
      "managerFilePatterns": [
        "/^scripts\\/split_tox_gh_actions\\/templates\\/(test_group|test_orchestrator)\\.jinja$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*(?:-[ \\t]+)?uses:[ \\t]+)getsentry\\/action-clickhouse-in-ci@(?<currentDigest>[a-f0-9]{40})[ \\t]+#[ \\t]+(?<currentValue>v?\\d+(?:\\.\\d+){0,2})"
      ],
      "depNameTemplate": "getsentry/action-clickhouse-in-ci",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "github-actions",
      "autoReplaceStringTemplate": "{{{indent}}}getsentry/action-clickhouse-in-ci@{{{currentDigest}}} # {{{newValue}}}"
    },
    {
      "customType": "regex",
      "description": "Update actions/setup-java in workflow templates",
      "managerFilePatterns": [
        "/^scripts\\/split_tox_gh_actions\\/templates\\/(test_group|test_orchestrator)\\.jinja$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*(?:-[ \\t]+)?uses:[ \\t]+)actions\\/setup-java@(?<currentDigest>[a-f0-9]{40})[ \\t]+#[ \\t]+(?<currentValue>v?\\d+(?:\\.\\d+){0,2})"
      ],
      "depNameTemplate": "actions/setup-java",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "github-actions",
      "autoReplaceStringTemplate": "{{{indent}}}actions/setup-java@{{{currentDigest}}} # {{{newValue}}}"
    },
    {
      "customType": "regex",
      "description": "Update actions/upload-artifact in workflow templates",
      "managerFilePatterns": [
        "/^scripts\\/split_tox_gh_actions\\/templates\\/(test_group|test_orchestrator)\\.jinja$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*(?:-[ \\t]+)?uses:[ \\t]+)actions\\/upload-artifact@(?<currentDigest>[a-f0-9]{40})[ \\t]+#[ \\t]+(?<currentValue>v?\\d+(?:\\.\\d+){0,2})"
      ],
      "depNameTemplate": "actions/upload-artifact",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "github-actions",
      "autoReplaceStringTemplate": "{{{indent}}}actions/upload-artifact@{{{currentDigest}}} # {{{newValue}}}"
    },
    {
      "customType": "regex",
      "description": "Update actions/download-artifact in workflow templates",
      "managerFilePatterns": [
        "/^scripts\\/split_tox_gh_actions\\/templates\\/(test_group|test_orchestrator)\\.jinja$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*(?:-[ \\t]+)?uses:[ \\t]+)actions\\/download-artifact@(?<currentDigest>[a-f0-9]{40})[ \\t]+#[ \\t]+(?<currentValue>v?\\d+(?:\\.\\d+){0,2})"
      ],
      "depNameTemplate": "actions/download-artifact",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "github-actions",
      "autoReplaceStringTemplate": "{{{indent}}}actions/download-artifact@{{{currentDigest}}} # {{{newValue}}}"
    }
  ]
}
